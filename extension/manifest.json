{
  "manifest_version": 3,
  "key": "",
  "name": "Browser Speech",
  "version": "0.1.0",
  "description": "System-wide high-quality TTS using Pocket TTS (audio.cpp)",
  "permissions": [
    "offscreen",
    "nativeMessaging",
    "sidePanel",
    "tts",
    "ttsEngine",
    "storage",
    "unlimitedStorage"
  ],
  "tts_engine": {},
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "options.html"
  },
  "options_page": "options.html",
  "action": {
    "default_title": "Browser Speech",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
